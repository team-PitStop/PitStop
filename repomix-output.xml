spring.application.name=backend

# --- Database (PostgreSQL) ---
# Each developer runs their own local Postgres (see docs/database-setup.md).
# DB_USER/DB_PASSWORD env vars can override; they default to your OS username
# with no password, which matches a local Homebrew/apt "trust" install.
spring.datasource.url=jdbc:postgresql://localhost:5432/pitstop
spring.datasource.username=${DB_USER:${user.name}}
spring.datasource.password=${DB_PASSWORD:}

# --- Schema management ---
# Flyway owns the schema (numbered migrations in db/migration). Hibernate only
# validates that the entities match the Flyway-built tables; it never alters them.
spring.jpa.hibernate.ddl-auto=validate
spring.flyway.enabled=true
spring.jpa.open-in-view=false

# --- JWT (login tokens) ---
# In any shared/deployed environment the secret comes from the JWT_SECRET env var.
# The default below is a throwaway for local dev only -- never a real secret.
jwt.secret=${JWT_SECRET:local-dev-only-secret-change-me-0123456789-0123456789}
jwt.expiration-ms=86400000
</file>

